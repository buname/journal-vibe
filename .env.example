# PostgreSQL — Prisma (single DATABASE_URL is enough for migrate + runtime)
#
# Supabase Session pooler (port 5432, host …pooler.supabase.com):
# - User MUST be postgres.<PROJECT_REF> (Project Settings → API → Project ID),
#   NOT plain "postgres". Wrong user → "FATAL: Tenant or user not found".
# - Example:
#   DATABASE_URL="postgresql://postgres.abcdefghijklmnop:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"
#
# If migrate fails only with Transaction pooler (6543), use Session pooler or the
# Supabase "Direct connection" URI as DATABASE_URL for local migrations.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trading_life_journal?schema=public"

# Auth.js / NextAuth (https://authjs.dev)
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
# Optional in development when trustHost is enabled
# AUTH_URL="http://localhost:3000"

# Skip strict env validation during local tooling (optional)
# SKIP_ENV_VALIDATION="true"
